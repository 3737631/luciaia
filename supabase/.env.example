# Variables de entorno para las Edge Functions de Supabase
# Se configuran con: supabase secrets set NOMBRE=valor
# O desde el dashboard: Edge Functions → chat → Environment variables

# REQUERIDO: API key de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-tu-key-aqui

# OPCIONAL: Modelo de OpenRouter (default: sao10k/l3-lunaris-8b)
OPENROUTER_MODEL=sao10k/l3-lunaris-8b
